{
  "$schema": "https://opencode.ai/config.json",
  "model": "github-copilot/claude-sonnet-4.6",

  "permission": {
    // Prevent access to paths outside the current repository
    "external_directory": { "*": "deny" },

    // Bash rules — broad rules first, specific last (last match wins)
    "bash": {
      "*":      "ask",
      "sudo *": "deny",
      "rm *":   "deny",
      "rmdir *":"deny",

      "acli *":    "allow",
      "bun *":     "allow",
      "cat *":     "allow",
      "echo *":    "allow",
      "find *":    "allow",
      "git *":     "allow",
      "go *":      "allow",
      "grep *":    "allow",
      "ls":        "allow",
      "ls *":      "allow",
      "make *":    "allow",
      "node *":    "allow",
      "npm *":     "allow",
      "npx *":     "allow",
      "pnpm *":    "allow",
      "pwd":       "allow",
      "python *":  "allow",
      "python3 *": "allow",
      "rg *":      "allow",
      "which *":   "allow",
      "yarn *":    "allow"
    }
  }
}
